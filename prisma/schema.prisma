generator client {
  // prisma-client is the new Rust-free client (replaces prisma-client-js)
  // output is required in Prisma 7 — client no longer goes to node_modules
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is now configured in prisma.config.ts (Prisma 7 breaking change)
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String?
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendance AttendanceRecord[]
  materials  Material[]
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  date        DateTime
  status      String   // "PRESENT" | "ABSENT"
  sessionType String   @default("THEORY") // "THEORY" | "LAB"
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
}

model Material {
  id        String   @id @default(cuid())
  title     String
  type      String   // "PDF" | "IMAGE" | "NOTE" | "LINK"
  url       String?  // file path (for PDF/IMAGE) or external URL (for LINK)
  content   String?  // markdown text (for NOTE)
  fileSize  Int?     // bytes, for uploaded files
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
}

model Document {
  id        String   @id @default(cuid())
  title     String
  type      String   // "PDF" | "IMAGE" | "NOTE" | "LINK"
  url       String?  // file path (for PDF/IMAGE) or external URL (for LINK)
  content   String?  // markdown text (for NOTE)
  fileSize  Int?     // bytes, for uploaded files
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id               String @id @default("singleton")
  targetAttendance Int    @default(75)
  academicYear     String @default("2025-26")
}
